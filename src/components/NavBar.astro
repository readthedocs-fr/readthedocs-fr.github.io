---
import DiscordLogo from "@/components/logos/DiscordLogo.astro";
import GitHubLogo from "@/components/logos/GitHubLogo.astro";
import YouTubeLogo from "@/components/logos/YouTubeLogo.astro";
import TwitchLogo from "@/components/logos/TwitchLogo.astro";
---

<nav aria-label="Navigation principale">
  <ul class="page-links">
    <li><a href="#about-us" class="anchor-link">À propos</a></li>
    <li><a href="#github" class="anchor-link">Projets</a></li>
    <li><a href="#youtube" class="anchor-link">YouTube</a></li>
  </ul>
  <div class="divider" aria-hidden="true"></div>
  <ul id="socials">
    <li>
      <a href="http://discord.readthedocs.fr/" class="nav-link discord">
        <DiscordLogo />
        <span>Discord</span>
      </a>
    </li>
    <li>
      <a href="http://github.readthedocs.fr/" class="nav-link github">
        <GitHubLogo />
        <span>GitHub</span>
      </a>
    </li>
    <li>
      <a href="http://youtube.readthedocs.fr/" class="nav-link youtube">
        <YouTubeLogo />
        <span>YouTube</span>
      </a>
    </li>
    <li>
      <a href="http://twitch.readthedocs.fr/" class="nav-link twitch">
        <TwitchLogo />
        <span>Twitch</span>
      </a>
    </li>
  </ul>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 0.25rem 1rem;
  }

  .page-links {
    list-style: none;
    display: flex;
    gap: 0.1rem;
    margin: 0;
    padding: 0.25rem 0;
  }

  .anchor-link {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border-radius: 50px;
    color: var(--text-secondary);
    font-family: "Commissioner", sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color var(--transition), background var(--transition);
  }

  .anchor-link:hover {
    color: var(--accent);
    background: var(--accent-glow);
  }

  .divider {
    width: 1px;
    height: 1.4rem;
    background: var(--border);
    margin: 0 0.5rem;
    flex-shrink: 0;
  }

  #socials {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin: 0;
    padding: 0.25rem 0;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 1.1rem;
    border-radius: 50px;
    color: var(--text-secondary);
    font-family: "Staatliches", cursive;
    font-size: 1.35rem;
    letter-spacing: 0.05em;
    transition: color var(--transition), background var(--transition), transform var(--transition);
  }

  .nav-link :global(svg) {
    fill: currentColor;
    height: 1.4rem;
    width: auto;
    flex-shrink: 0;
  }

  .nav-link:hover {
    transform: translateY(-2px);
  }

  .nav-link.discord:hover {
    color: #7289da;
    background: rgba(114, 137, 218, 0.12);
  }

  .nav-link.github:hover {
    color: #3fb950;
    background: rgba(63, 185, 80, 0.1);
  }

  .nav-link.youtube:hover {
    color: #ff4444;
    background: rgba(255, 68, 68, 0.1);
  }

  .nav-link.twitch:hover {
    color: #bf94ff;
    background: rgba(191, 148, 255, 0.12);
  }
</style>
</style>
