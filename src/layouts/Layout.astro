---
import NavBar from "@/components/NavBar.astro";
import ReadTheDocsFRLogo from "@/components/logos/ReadTheDocsFRLogo.astro";
import "@/styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

// TODO servir les fonts localement
---

<!doctype html>
<html lang="fr">
  <head>
    <title>{title}</title>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:title" content="RTD FR | Read The Docs FR" />
    <meta
      property="og:description"
      content="Rejoignez une communauté francophone de développeurs axée sur l'entraide et le travail collaboratif autour de projets open source"
    />
    <meta property="og:site_name" content="Read The Docs FR" />
    <meta property="og:type" content="website" />
    <meta
      name="description"
      content="Rejoignez une communauté francophone de développeurs axée sur l'entraide et le travail collaboratif autour de projets open source"
    />
    <meta name="author" content="Antoine JT" />
    <link
      href="https://fonts.googleapis.com/css2?family=Overpass:wght@300;400;600&family=Commissioner:wght@400;600&family=Staatliches&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="header-ambient" aria-hidden="true"></div>
      <div class="logo-wrapper">
        <ReadTheDocsFRLogo />
      </div>
      <p class="tagline">Communauté francophone de développeurs</p>
    </header>
    <NavBar />
    <main>
      <slot />
    </main>
    <footer>
      <p>
        Le <a href="https://github.com/readthedocs-fr/readthedocs-fr.github.io"
          >code source</a
        > de ce site est disponible sur GitHub.
      </p>
    </footer>
  </body>
</html>

<style>
  header {
    position: relative;
    text-align: center;
    padding: 3.5rem 1rem 2rem;
    overflow: hidden;
  }

  .header-ambient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 80% at 50% 0%, rgba(0, 230, 118, 0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  .logo-wrapper {
    display: inline-block;
    position: relative;
    filter: drop-shadow(0 0 32px rgba(0, 230, 118, 0.25));
    transition: filter 0.4s ease;
  }

  .logo-wrapper:hover {
    filter: drop-shadow(0 0 48px rgba(0, 230, 118, 0.45));
  }

  .logo-wrapper :global(svg) {
    height: clamp(80px, 16vh, 160px);
    display: block;
  }

  .tagline {
    margin: 1rem 0 0;
    color: var(--text-secondary);
    font-family: "Commissioner", sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  footer {
    color: var(--text-secondary);
    text-align: center;
    padding: 2rem 1rem;
    font-size: 0.875rem;
    font-family: "Commissioner", sans-serif;
    border-top: 1px solid var(--border);
    margin-top: 5rem;
  }

  footer :global(a) {
    color: var(--accent);
  }

  footer :global(a):hover {
    color: var(--accent-dim);
  }
</style>
