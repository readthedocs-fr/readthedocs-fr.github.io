---
import NavBar from "@/components/NavBar.astro";
import ReadTheDocsFRLogo from "@/components/logos/ReadTheDocsFRLogo.astro";
import "@/styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

// TODO servir les fonts localement
---

<!doctype html>
<html lang="fr">
  <head>
    <title>{title}</title>

    <!-- Anti-FOUC : applique le thème sauvegardé avant le premier rendu -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem("rtd-theme") === "light") {
            document.documentElement.setAttribute("data-theme", "light");
          }
        } catch (_) {}
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:title" content="RTD FR | Read The Docs FR" />
    <meta
      property="og:description"
      content="Rejoignez une communauté francophone de développeurs axée sur l'entraide et le travail collaboratif autour de projets open source"
    />
    <meta property="og:site_name" content="Read The Docs FR" />
    <meta property="og:type" content="website" />
    <meta
      name="description"
      content="Rejoignez une communauté francophone de développeurs axée sur l'entraide et le travail collaboratif autour de projets open source"
    />
    <meta name="author" content="Antoine JT" />
    <link
      href="https://fonts.googleapis.com/css2?family=Overpass:wght@300;400;600&family=Commissioner:wght@400;600&family=Staatliches&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="header-ambient" aria-hidden="true"></div>
      <div class="logo-wrapper">
        <ReadTheDocsFRLogo />
      </div>
      <p class="tagline">Communauté francophone de développeurs</p>

      <button id="theme-toggle" aria-label="Changer de thème" title="Basculer thème clair / sombre">
        <!-- Sombre -> Clair -->
        <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Clair -> Sombre -->
        <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </header>
    <NavBar />
    <main>
      <slot />
    </main>

    <button id="back-to-top" aria-label="Retour en haut de page">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <footer>
      <p>
        Le <a href="https://github.com/readthedocs-fr/readthedocs-fr.github.io"
          >code source</a
        > de ce site est disponible sur GitHub.
      </p>
    </footer>

    <script is:inline>
      // ── Thème ──────────────────────────────────────────────────
      const toggle = document.getElementById("theme-toggle");
      const html = document.documentElement;

      function applyTheme(theme) {
        if (theme === "light") {
          html.setAttribute("data-theme", "light");
        } else {
          html.removeAttribute("data-theme");
        }
        try { localStorage.setItem("rtd-theme", theme); } catch (_) {}
      }

      toggle.addEventListener("click", () => {
        applyTheme(html.getAttribute("data-theme") === "light" ? "dark" : "light");
      });

      // ── Retour en haut ─────────────────────────────────────────
      const btn = document.getElementById("back-to-top");

      window.addEventListener("scroll", () => {
        btn.classList.toggle("visible", window.scrollY > 300);
      }, { passive: true });

      btn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    </script>
  </body>
</html>

<style>
  header {
    position: relative;
    text-align: center;
    padding: 3.5rem 1rem 2rem;
    overflow: hidden;
  }

  .header-ambient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 80% at 50% 0%, var(--header-glow) 0%, transparent 65%);
    pointer-events: none;
  }

  .logo-wrapper {
    display: inline-block;
    position: relative;
    filter: drop-shadow(0 0 32px rgba(0, 230, 118, 0.25));
    transition: filter 0.4s ease;
  }

  .logo-wrapper:hover {
    filter: drop-shadow(0 0 48px rgba(0, 230, 118, 0.45));
  }

  .logo-wrapper :global(svg) {
    height: clamp(80px, 16vh, 160px);
    display: block;
  }

  .tagline {
    margin: 1rem 0 0;
    color: var(--text-secondary);
    font-family: "Commissioner", sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* ── Bouton de thème ── */
  #theme-toggle {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 2.6rem;
    height: 2.6rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: border-color var(--transition), color var(--transition), background var(--transition);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  #theme-toggle:hover {
    border-color: var(--border-hover);
    color: var(--accent);
    background: var(--accent-glow);
  }

  #theme-toggle :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }

  /* ── Footer ── */
  footer {
    color: var(--text-secondary);
    text-align: center;
    padding: 2rem 1rem;
    font-size: 0.875rem;
    font-family: "Commissioner", sans-serif;
    border-top: 1px solid var(--border);
    margin-top: 5rem;
  }

  footer :global(a) {
    color: var(--accent);
  }

  footer :global(a):hover {
    color: var(--accent-dim);
  }
</style>
